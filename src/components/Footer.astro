---
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-mark">CW</span>
          Crossword<span class="footer-logo-dot">Solver</span>
        </a>
        <p class="footer-desc">
          Your daily destination for crossword answers and solver tools. Covering NYT, Guardian, LA Times, Atlantic, USA Today, and more.
        </p>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-links-title">Popular Puzzles</h4>
        <a href="/nyt-crossword-answer-today">NYT Crossword</a>
        <a href="/nyt-mini-crossword-answer-today">NYT Mini</a>
        <a href="/crossword-solver">Crossword Solver</a>
        <a href="/atlantic-crossword-answer-today">Atlantic</a>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-links-title">More Puzzles</h4>
        <a href="/guardian-quick-crossword-answer-today">Guardian Quick</a>
        <a href="/guardian-cryptic-crossword-answer-today">Guardian Cryptic</a>
        <a href="/la-times-crossword-answer-today">LA Times</a>
        <a href="/washington-post-crossword-answer-today">Washington Post</a>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-links-title">Archives</h4>
        <a href="/archive">All Crossword Archives</a>
        <a href="/archive">NYT Archive</a>
        <a href="/archive">Guardian Archive</a>
        <a href="/archive">LA Times Archive</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} CrosswordSolver. All rights reserved.</p>
      <p class="footer-disclaimer">Not affiliated with The New York Times, The Guardian, or any other puzzle publisher.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: 48px 0 24px;
    margin-top: 64px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .footer-brand { max-width: 280px; }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 12px;
    text-decoration: none;
  }
  .footer-logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: var(--color-accent);
    color: white;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 800;
  }
  .footer-logo-dot { color: var(--color-accent); }

  .footer-desc {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .footer-links-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-links-title {
    color: var(--color-text);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .footer-links-group a {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    transition: color 0.15s;
  }
  .footer-links-group a:hover { color: var(--color-accent); }

  .footer-bottom {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  .footer-disclaimer { font-style: italic; }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer-brand { grid-column: 1 / -1; max-width: 100%; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; gap: 20px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

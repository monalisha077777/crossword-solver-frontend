---
interface Props {
  date: string;
  title: string;
  subtitle?: string;
  across: Record<string, { clue: string; answer: string }>;
  down: Record<string, { clue: string; answer: string }>;
  showAnswers?: boolean;
}

const { date, title, subtitle, across, down, showAnswers = true } = Astro.props;

const acrossEntries = Object.entries(across || {}).sort(([a], [b]) => parseInt(a) - parseInt(b));
const downEntries = Object.entries(down || {}).sort(([a], [b]) => parseInt(a) - parseInt(b));

function formatDate(dateStr: string): string {
  try {
    return new Date(`${dateStr}T00:00:00`).toLocaleDateString('en-US', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateStr;
  }
}
---

<div class="puzzle-display fade-in">
  <div class="puzzle-header">
    <div class="puzzle-meta">
      <span class="badge badge-accent">{formatDate(date)}</span>
      {subtitle && <span class="puzzle-subtitle">{subtitle}</span>}
    </div>
    <h1 class="puzzle-title">{title}</h1>
    <div class="puzzle-stats">
      <span class="stat">
        <span class="stat-icon across-icon">→</span>
        {acrossEntries.length} Across
      </span>
      <span class="stat">
        <span class="stat-icon down-icon">↓</span>
        {downEntries.length} Down
      </span>
    </div>
  </div>

  <div class="puzzle-actions-bar">
    <button class="btn btn-secondary" id="toggleAnswersBtn" data-show={showAnswers ? 'true' : 'false'}>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 3C4.5 3 1.7 5.1 0 8c1.7 2.9 4.5 5 8 5s6.3-2.1 8-5c-1.7-2.9-4.5-5-8-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
      </svg>
      {showAnswers ? 'Hide Answers' : 'Show Answers'}
    </button>
  </div>

  <div class="puzzle-grid">
    <div class="clues-section">
      <div class="clues-section-header">
        <span class="clues-direction across">ACROSS</span>
      </div>
      <div class="clues-list">
        {acrossEntries.map(([num, data]) => (
          <div class="clue-row" data-answer={data.answer}>
            <span class="clue-number across">{num}</span>
            <span class="clue-text">{data.clue}</span>
            <span class={`clue-answer ${showAnswers ? '' : 'hidden-answer'}`}>{data.answer}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="clues-section">
      <div class="clues-section-header">
        <span class="clues-direction down">DOWN</span>
      </div>
      <div class="clues-list">
        {downEntries.map(([num, data]) => (
          <div class="clue-row" data-answer={data.answer}>
            <span class="clue-number down">{num}</span>
            <span class="clue-text">{data.clue}</span>
            <span class={`clue-answer ${showAnswers ? '' : 'hidden-answer'}`}>{data.answer}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('toggleAnswersBtn');
  btn?.addEventListener('click', () => {
    const answers = document.querySelectorAll('.clue-answer');
    const isShowing = btn.getAttribute('data-show') === 'true';
    answers.forEach(a => a.classList.toggle('hidden-answer', isShowing));
    btn.setAttribute('data-show', isShowing ? 'false' : 'true');
    btn.innerHTML = isShowing
      ? `<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 3C4.5 3 1.7 5.1 0 8c1.7 2.9 4.5 5 8 5s6.3-2.1 8-5c-1.7-2.9-4.5-5-8-5zm0 8a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg> Show Answers`
      : `<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M13.2 2.8L2.8 13.2M2.8 2.8l10.4 10.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> Hide Answers`;
  });
</script>

<style>
  .puzzle-display {
    max-width: 900px;
    margin: 0 auto;
  }

  .puzzle-header {
    margin-bottom: 32px;
  }

  .puzzle-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .puzzle-subtitle {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .puzzle-title {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    background: linear-gradient(135deg, var(--color-text), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .puzzle-stats {
    display: flex;
    gap: 20px;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .stat-icon {
    font-weight: 700;
    font-size: 1rem;
  }

  .across-icon {
    color: var(--color-across);
  }

  .down-icon {
    color: var(--color-down);
  }

  .puzzle-actions-bar {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .puzzle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .clues-section-header {
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-border);
  }

  .clues-direction {
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .clues-direction.across {
    color: var(--color-across);
  }

  .clues-direction.down {
    color: var(--color-down);
  }

  .clues-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .clue-row {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
  }

  .clue-row:hover {
    background: var(--color-accent-light);
  }

  .clue-number {
    font-weight: 700;
    font-size: 0.9rem;
    font-family: var(--font-mono);
  }

  .clue-number.across {
    color: var(--color-across);
  }

  .clue-number.down {
    color: var(--color-down);
  }

  .clue-text {
    color: var(--color-text);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .clue-answer {
    font-weight: 700;
    font-size: 0.9rem;
    font-family: var(--font-mono);
    color: var(--color-success);
    letter-spacing: 1px;
    text-align: right;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .hidden-answer {
    color: transparent;
    background: var(--color-bg-card);
    border-radius: 4px;
    filter: blur(4px);
    user-select: none;
    min-width: 60px;
  }

  .hidden-answer:hover {
    filter: blur(0);
    color: var(--color-success);
    background: transparent;
  }

  @media (max-width: 768px) {
    .puzzle-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .puzzle-title {
      font-size: 1.5rem;
    }

    .clue-row {
      grid-template-columns: 30px 1fr;
      gap: 6px;
    }

    .clue-answer {
      grid-column: 2;
      text-align: left;
    }

    .hidden-answer {
      min-width: 50px;
    }
  }

  @media (max-width: 480px) {
    .puzzle-title {
      font-size: 1.3rem;
    }
  }
</style>

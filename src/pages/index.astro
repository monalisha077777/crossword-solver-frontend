---
import MainLayout from '../layouts/MainLayout.astro';
import { CROSSWORD_SOURCES } from '../lib/api';
---

<MainLayout title="Home" canonicalUrl="https://crosswordsolver.dev">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-badge">Daily Crossword Answers</span>
        <h1 class="hero-title">
          Every Crossword<br/>
          Answer, Every Day
        </h1>
        <p class="hero-desc">
          Get today's complete crossword answers for NYT, Guardian, LA Times, Atlantic, and more.
          Use our powerful solver to crack any clue instantly.
        </p>
        <div class="hero-actions">
          <a href="/crossword-solver" class="btn btn-primary btn-lg">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
            Open Solver
          </a>
          <a href="#puzzles" class="btn btn-secondary btn-lg">Browse Puzzles</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="solver-demo-card">
          <div class="demo-header">Crossword Solver</div>
          <div class="demo-row">
            <span class="demo-label">Clue</span>
            <span class="demo-value">"Cookie brand"</span>
          </div>
          <div class="demo-row">
            <span class="demo-label">Pattern</span>
            <span class="demo-value demo-mono">O?E?</span>
          </div>
          <div class="demo-divider"></div>
          <div class="demo-result">
            <span class="demo-answer">OREO</span>
            <span class="badge badge-success">Match Found</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Puzzle Grid -->
  <section class="puzzles-section" id="puzzles">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Today's Crossword Answers</h2>
        <p class="section-subtitle">Select a puzzle to view the complete solution</p>
      </div>

      <div class="source-grid">
        {CROSSWORD_SOURCES.map(source => (
          <a href={source.todayPath} class="source-card">
            <div class="source-card-color" style={`background:${source.color}`}></div>
            <div class="source-card-body">
              <h3 class="source-card-name">{source.name}</h3>
              <p class="source-card-desc">{source.description}</p>
            </div>
            <svg class="source-card-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 4l5 5-5 5"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Solver CTA -->
  <section class="solver-cta-section">
    <div class="container">
      <div class="solver-cta-card">
        <div class="cta-content">
          <h2 class="cta-title">Stuck on a Clue?</h2>
          <p class="cta-desc">
            Our crossword solver searches millions of clues from multiple archives and databases.
            Enter any clue with an optional letter pattern to find the answer instantly.
          </p>
          <a href="/crossword-solver" class="btn btn-primary btn-lg">
            Try the Solver
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
          </a>
        </div>
        <div class="cta-features">
          <div class="cta-feature">
            <span class="cta-feature-num">1</span>
            <div>
              <strong>Archive Search</strong>
              <p>Matches from millions of stored crossword clues</p>
            </div>
          </div>
          <div class="cta-feature">
            <span class="cta-feature-num">2</span>
            <div>
              <strong>Pattern Matching</strong>
              <p>Filter by known letters like C??E or ?R??E</p>
            </div>
          </div>
          <div class="cta-feature">
            <span class="cta-feature-num">3</span>
            <div>
              <strong>Multi-Source</strong>
              <p>Falls back to CrosswordNexus and Datamuse</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: 64px 0 48px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 5px 14px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 3.2rem;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .hero-desc {
    color: var(--color-text-secondary);
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Solver Demo Card */
  .solver-demo-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 24px;
    max-width: 380px;
    margin-left: auto;
    box-shadow: var(--shadow-lg);
  }

  .demo-header {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .demo-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    margin-bottom: 8px;
  }

  .demo-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-muted);
    min-width: 55px;
  }

  .demo-value { color: var(--color-text); font-size: 0.92rem; }
  .demo-mono { font-family: var(--font-mono); letter-spacing: 2px; }

  .demo-divider {
    height: 1px;
    background: var(--color-border);
    margin: 12px 0;
  }

  .demo-result {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    background: var(--color-success-light);
    border: 1px solid rgba(13,144,79,0.15);
    border-radius: var(--radius-sm);
  }

  .demo-answer {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--color-success);
    letter-spacing: 2px;
  }

  /* ===== Source Grid ===== */
  .puzzles-section {
    padding: 56px 0;
  }

  .section-head {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 12px;
  }

  .source-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 20px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.15s;
  }
  .source-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .source-card-color {
    width: 4px;
    height: 40px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .source-card-body { flex: 1; min-width: 0; }

  .source-card-name {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 3px;
  }

  .source-card-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .source-card-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .source-card:hover .source-card-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  /* ===== Solver CTA ===== */
  .solver-cta-section { padding: 24px 0 56px; }

  .solver-cta-card {
    background: var(--color-accent);
    border-radius: var(--radius-xl);
    padding: 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    color: white;
  }

  .cta-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 14px;
    letter-spacing: -0.5px;
  }

  .cta-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .cta-content .btn-primary {
    background: white;
    color: var(--color-accent);
  }
  .cta-content .btn-primary:hover {
    background: #f0f0f0;
  }

  .cta-features {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cta-feature {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .cta-feature-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .cta-feature strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 2px;
  }

  .cta-feature p {
    font-size: 0.82rem;
    opacity: 0.8;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .hero-container { grid-template-columns: 1fr; text-align: center; }
    .hero-desc { max-width: 100%; margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-visual { display: none; }
    .hero-title { font-size: 2.4rem; }
    .solver-cta-card { grid-template-columns: 1fr; padding: 32px; }
    .source-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .hero { padding: 40px 0 32px; }
    .hero-title { font-size: 1.9rem; }
    .section-title { font-size: 1.4rem; }
    .solver-cta-card { padding: 24px; }
    .cta-title { font-size: 1.5rem; }
  }
</style>

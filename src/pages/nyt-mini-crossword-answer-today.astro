---
import MainLayout from '../layouts/MainLayout.astro';
import PuzzleDisplay from '../components/PuzzleDisplay.astro';
import { fetchLatestMiniPuzzle, API_BASES } from '../lib/api';

let puzzleData = null;
let puzzleDate = '';
let error = '';

try {
  const data = await fetchLatestMiniPuzzle();
  if (data.success && data.data) {
    puzzleData = data.data;
    puzzleDate = data.date || '';
  } else {
    error = 'No mini puzzle found for today.';
  }
} catch (e: any) {
  error = e.message || 'Failed to fetch mini puzzle data.';
}
---

<MainLayout title="NYT Mini Crossword Answers Today" description="Today's NYT Mini Crossword answers and solutions. Quick answers for the New York Times Mini crossword puzzle.">
  <section class="page-section">
    <div class="container">
      <div class="page-breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>NYT Mini Crossword</span>
      </div>

      {puzzleData ? (
        <PuzzleDisplay
          date={puzzleDate}
          title="NYT Mini Crossword Answers Today"
          subtitle="The New York Times Mini Crossword"
          across={puzzleData.across || {}}
          down={puzzleData.down || {}}
          showAnswers={true}
        />
      ) : (
        <div class="error-state">
          <div class="error-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="22" stroke="#ff6b6b" stroke-width="2"/>
              <path d="M24 16v12M24 32v2" stroke="#ff6b6b" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h2 class="error-title">Unable to Load Mini Puzzle</h2>
          <p class="error-msg">{error || 'Something went wrong while fetching the mini puzzle data.'}</p>
          <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
      )}

      <div class="page-content-section">
        <h2 class="content-heading">About the NYT Mini Crossword</h2>
        <p class="content-text">
          The New York Times Mini Crossword is a compact 5x5 grid puzzle introduced in 2014, designed to be completed in just a few minutes. Despite its small size, the Mini packs a punch with clever clues that range from straightforward to surprisingly tricky. It has become incredibly popular as a quick daily mental exercise, often solved during commutes or coffee breaks.
        </p>
        <p class="content-text">
          Our page provides the complete answers for today's NYT Mini Crossword. Whether you need help with a single clue or want to check your completed grid, we offer accurate solutions organized by Across and Down clues. The Mini is a great entry point for new crossword solvers and a satisfying quick solve for experienced puzzlers.
        </p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-section {
    padding: 32px 0 48px;
  }

  .page-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .page-breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .page-breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb-sep {
    color: var(--color-border-light);
  }

  .error-state {
    text-align: center;
    padding: 64px 24px;
    max-width: 500px;
    margin: 0 auto;
  }

  .error-icon {
    margin-bottom: 20px;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .error-msg {
    color: var(--color-text-muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .page-content-section {
    margin-top: 48px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .content-heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .content-text {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 16px;
  }
</style>

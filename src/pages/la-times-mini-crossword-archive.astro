---
import MainLayout from '../layouts/MainLayout.astro';
import PuzzleDisplay from '../components/PuzzleDisplay.astro';
import { fetchPuzzleByDate, CROSSWORD_SOURCES, getTodayStr, formatDateDisplay } from '../lib/api';

const source = CROSSWORD_SOURCES.find(s => s.slug === 'latimes-mini')!;
const today = getTodayStr();
const requestedDate = Astro.url.searchParams.get('date') || today;

function getPrevDate(dateStr: string): string {
  const d = new Date(`${dateStr}T12:00:00`);
  d.setDate(d.getDate() - 1);
  return d.toISOString().split('T')[0];
}

function getNextDate(dateStr: string, maxDate: string): string {
  const d = new Date(`${dateStr}T12:00:00`);
  const max = new Date(`${maxDate}T12:00:00`);
  d.setDate(d.getDate() + 1);
  if (d > max) return maxDate;
  return d.toISOString().split('T')[0];
}

let puzzle = null;
let error = '';

try {
  puzzle = await fetchPuzzleByDate(source.baseUrl, requestedDate);
  if (!puzzle) error = `No puzzle found for ${formatDateDisplay(requestedDate)}.`;
} catch (e: any) {
  error = e.message || 'Failed to fetch puzzle data.';
}

export const prerender = false;
---

<MainLayout title="LA Times Mini Crossword Archive" description="Browse the complete archive of LA Times Mini Crossword answers. Search by date to find past puzzle solutions.">
  <section class="page-section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="bc-sep">/</span>
        <a href="/la-times-mini-crossword-answer-today">LA Times Mini</a>
        <span class="bc-sep">/</span>
        <span>Archive</span>
      </nav>

      <div class="archive-header">
        <h1 class="archive-title">LA Times Mini Crossword Archive</h1>
        <p class="archive-desc">Browse past LA Times Mini Crossword answers by date</p>
      </div>

      <div class="date-picker-card">
        <form method="get" class="date-form">
          <label for="date-input" class="date-label">Select Date</label>
          <div class="date-input-row">
            <input type="date" id="date-input" name="date" value={requestedDate} max={today} class="date-input" />
            <button type="submit" class="btn btn-primary">Go</button>
          </div>
        </form>
        <div class="date-nav">
          <a href={`/la-times-mini-crossword-archive?date=${getPrevDate(requestedDate)}`} class="btn btn-ghost">&larr; Previous Day</a>
          <a href={`/la-times-mini-crossword-archive?date=${getNextDate(requestedDate, today)}`} class="btn btn-ghost">Next Day &rarr;</a>
        </div>
      </div>

      {puzzle ? (
        <PuzzleDisplay
          date={puzzle.date}
          formattedDate={puzzle.formattedDate}
          title={puzzle.title || `LA Times Mini — ${formatDateDisplay(requestedDate)}`}
          author={puzzle.author}
          editor={puzzle.editor}
          dayOfWeek={puzzle.dayOfWeek}
          across={puzzle.across}
          down={puzzle.down}
          showAnswers={true}
          sourceColor={source.color}
        />
      ) : (
        <div class="error-state">
          <h2 class="error-title">No Puzzle Found</h2>
          <p class="error-msg">{error}</p>
          <a href={`/la-times-mini-crossword-archive?date=${today}`} class="btn btn-secondary">View Today's Puzzle</a>
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .page-section { padding: 24px 0 48px; }
  .breadcrumb { display: flex; align-items: center; gap: 6px; margin-bottom: 20px; font-size: 0.82rem; color: var(--color-text-muted); }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-accent); }
  .bc-sep { color: var(--color-border); }
  .archive-header { margin-bottom: 24px; }
  .archive-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 6px; }
  .archive-desc { color: var(--color-text-muted); font-size: 0.92rem; }
  .date-picker-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 20px;
    margin-bottom: 28px;
    box-shadow: var(--shadow-sm);
  }
  .date-form { display: flex; align-items: flex-end; gap: 12px; margin-bottom: 12px; }
  .date-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-secondary); display: block; margin-bottom: 5px; }
  .date-input-row { display: flex; gap: 8px; }
  .date-input {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text);
    background: var(--color-bg);
  }
  .date-input:focus { border-color: var(--color-accent); box-shadow: 0 0 0 3px var(--color-accent-light); }
  .date-nav { display: flex; gap: 8px; }
  .error-state { text-align: center; padding: 48px 24px; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-lg); max-width: 480px; margin: 0 auto; }
  .error-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
  .error-msg { color: var(--color-text-muted); margin-bottom: 20px; }
</style>

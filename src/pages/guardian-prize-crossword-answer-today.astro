---
import MainLayout from '../layouts/MainLayout.astro';
import PuzzleDisplay from '../components/PuzzleDisplay.astro';
import { fetchLatestPuzzle, CROSSWORD_SOURCES } from '../lib/api';

const source = CROSSWORD_SOURCES.find(s => s.slug === 'guardian-prize')!;
let puzzle = null;
let error = '';

try {
  puzzle = await fetchLatestPuzzle(source.baseUrl);
  if (!puzzle) error = 'No puzzle found for today. Check back later!';
} catch (e: any) {
  error = e.message || 'Failed to fetch puzzle data.';
}

---

<MainLayout title="Guardian Prize Crossword Answers Today" description="Today's Guardian Prize Crossword answers and solutions.">
  <section class="page-section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="bc-sep">/</span>
        <span>Guardian Prize</span>
      </nav>

      {puzzle ? (
        <PuzzleDisplay
          date={puzzle.date}
          formattedDate={puzzle.formattedDate}
          title={puzzle.title || 'Guardian Prize Answers Today'}
          author={puzzle.author}
          editor={puzzle.editor}
          dayOfWeek={puzzle.dayOfWeek}
          across={puzzle.across}
          down={puzzle.down}
          showAnswers={true}
          sourceColor={source.color}
          archiveLink="/archive"
        />
      ) : (
        <div class="error-state">
          <div class="error-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="22" stroke="#d93025" stroke-width="2"/>
              <path d="M24 16v12M24 32v2" stroke="#d93025" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h2 class="error-title">Unable to Load Puzzle</h2>
          <p class="error-msg">{error}</p>
          <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
      )}

      <div class="content-section">
        <h2 class="content-heading">About the Guardian Prize</h2>
        <p class="content-text">{source.description}. Our page provides the complete answers for today's puzzle, organized by Across and Down clues.</p>
        <div class="content-links">
          <a href="/archive" class="btn btn-ghost">Browse Archive</a>
          <a href="/crossword-solver" class="btn btn-ghost">Open Solver</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-section { padding: 24px 0 48px; }
  .breadcrumb { display: flex; align-items: center; gap: 6px; margin-bottom: 20px; font-size: 0.82rem; color: var(--color-text-muted); }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-accent); }
  .bc-sep { color: var(--color-border); }
  .error-state { text-align: center; padding: 56px 24px; max-width: 480px; margin: 0 auto; background: var(--color-bg-card); border-radius: var(--radius-lg); border: 1px solid var(--color-border); }
  .error-icon { margin-bottom: 16px; }
  .error-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
  .error-msg { color: var(--color-text-muted); margin-bottom: 20px; line-height: 1.6; font-size: 0.9rem; }
  .content-section { margin-top: 40px; max-width: 760px; margin-left: auto; margin-right: auto; }
  .content-heading { font-size: 1.3rem; font-weight: 700; margin-bottom: 14px; }
  .content-text { color: var(--color-text-secondary); font-size: 0.92rem; line-height: 1.8; margin-bottom: 14px; }
  .content-links { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
</style>
